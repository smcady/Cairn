{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/bootstrap.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CAIRN_VENV}/bin/python\" \"${CLAUDE_PLUGIN_ROOT}/scripts/hook_ingest.py\"",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CAIRN_VENV}/bin/python\" \"${CLAUDE_PLUGIN_ROOT}/scripts/hook_orient.py\"",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
